{
  "targets": {
    "release": {
      "outFile": "modules/wasm/hero-core.wasm",
      "textFile": "build/wasm/hero-sim.wat",
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": false,
      "noAssert": true
    },
    "debug": {
      "outFile": "build/wasm/hero-sim.debug.wasm",
      "sourceMap": true,
      "debug": true
    }
  },
  "options": {
    "bindings": "raw",
    "exportRuntime": true
  }
}
