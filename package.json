{
  "name": "and3rn3t-portfolio",
  "version": "2.0.0",
  "description": "Matthew Anderson's Portfolio Website",
  "type": "module",
  "homepage": "https://andernet.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/and3rn3t/and3rn3t"
  },
  "bugs": {
    "url": "https://github.com/and3rn3t/and3rn3t/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "python3 -m http.server 8000",
    "build:wasm": "asc assembly/hero-sim.ts --config asconfig.json --target release && node -e \"const { rmSync } = require('node:fs'); rmSync('modules/wasm/hero-core.js', { force: true }); rmSync('modules/wasm/hero-core.d.ts', { force: true });\"",
    "build:wasm:debug": "asc assembly/hero-sim.ts --config asconfig.json --target debug",
    "build:worker": "wrangler deploy --dry-run --outdir dist-worker",
    "deploy:worker": "wrangler deploy",
    "worker:dev": "wrangler dev worker/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm lint && pnpm format:check && pnpm test:unit && pnpm build",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "assemblyscript": "^0.28.19",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "portfolio",
    "github-pages",
    "es-modules",
    "cloudflare-workers",
    "vanilla-js"
  ],
  "author": "Matthew Anderson",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
